{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://novelfactory.local/schema/v1/story-bible.schema.json",
  "title": "StoryBible v1",
  "type": "object",
  "required": [
    "metadata",
    "project_id",
    "title_working",
    "genre",
    "target_platform",
    "audience",
    "story_dna",
    "world_bible",
    "character_bible",
    "hard_constraints",
    "ending_direction"
  ],
  "properties": {
    "metadata": {
      "$ref": "common.schema.json#/$defs/metadata"
    },
    "project_id": {
      "$ref": "common.schema.json#/$defs/project_id"
    },
    "title_working": {
      "type": "string",
      "minLength": 1
    },
    "genre": {
      "$ref": "common.schema.json#/$defs/genre_array"
    },
    "target_platform": {
      "type": "string"
    },
    "audience": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "story_dna": {
      "type": "object",
      "required": [
        "core_promise",
        "main_conflict",
        "theme"
      ],
      "properties": {
        "core_promise": {
          "type": "string"
        },
        "main_conflict": {
          "type": "string"
        },
        "theme": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "world_bible": {
      "type": "object",
      "required": [
        "rules",
        "factions",
        "economy",
        "power_system"
      ],
      "properties": {
        "rules": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "factions": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "economy": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "power_system": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      },
      "additionalProperties": false
    },
    "character_bible": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "hard_constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "ending_direction": {
      "type": "string"
    }
  },
  "additionalProperties": false
}

