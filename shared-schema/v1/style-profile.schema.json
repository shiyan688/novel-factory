{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://novelfactory.local/schema/v1/style-profile.schema.json",
  "title": "StyleProfile v1",
  "type": "object",
  "required": [
    "metadata",
    "style_id",
    "name",
    "tone",
    "dialogue_density",
    "avg_sentence_length",
    "twist_frequency_per_10k",
    "hook_strength"
  ],
  "properties": {
    "metadata": {
      "$ref": "common.schema.json#/$defs/metadata"
    },
    "style_id": {
      "$ref": "common.schema.json#/$defs/style_id"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "tone": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "dialogue_density": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "avg_sentence_length": {
      "type": "number",
      "minimum": 1
    },
    "twist_frequency_per_10k": {
      "type": "number",
      "minimum": 0
    },
    "hook_strength": {
      "type": "number",
      "minimum": 0,
      "maximum": 10
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": false
}

