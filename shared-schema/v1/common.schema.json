{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://novelfactory.local/schema/v1/common.schema.json",
  "title": "Common Definitions v1",
  "type": "object",
  "$defs": {
    "schema_version": {
      "type": "string",
      "const": "v1"
    },
    "producer": {
      "type": "string",
      "enum": [
        "project-a",
        "project-b",
        "shared"
      ]
    },
    "metadata": {
      "type": "object",
      "required": [
        "schema_version",
        "producer",
        "created_at",
        "updated_at"
      ],
      "properties": {
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "producer": {
          "$ref": "#/$defs/producer"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "book_id": {
      "type": "string",
      "pattern": "^book_[A-Za-z0-9_-]+$"
    },
    "project_id": {
      "type": "string",
      "pattern": "^proj_[A-Za-z0-9_-]+$"
    },
    "character_id": {
      "type": "string",
      "pattern": "^char_[A-Za-z0-9_-]+$"
    },
    "arc_id": {
      "type": "string",
      "pattern": "^arc_[A-Za-z0-9_-]+$"
    },
    "chapter_id": {
      "type": "string",
      "pattern": "^ch_[A-Za-z0-9_-]+$"
    },
    "scene_id": {
      "type": "string",
      "pattern": "^sc_[A-Za-z0-9_-]+$"
    },
    "pattern_id": {
      "type": "string",
      "pattern": "^pat_[A-Za-z0-9_-]+$"
    },
    "style_id": {
      "type": "string",
      "pattern": "^style_[A-Za-z0-9_-]+$"
    },
    "memory_event_id": {
      "type": "string",
      "pattern": "^memevt_[A-Za-z0-9_-]+$"
    },
    "foreshadow_id": {
      "type": "string",
      "pattern": "^fo_[A-Za-z0-9_-]+$"
    },
    "genre_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "pattern_type": {
      "type": "string",
      "enum": [
        "opening_hook",
        "mid_twist",
        "chapter_cliffhanger",
        "power_escalation",
        "faction_conflict",
        "relationship_push",
        "foreshadow_setup",
        "foreshadow_payoff"
      ]
    },
    "issue_type": {
      "type": "string",
      "enum": [
        "continuity",
        "character_consistency",
        "timeline",
        "power_scaling",
        "style_drift",
        "hook_weakness"
      ]
    },
    "visibility": {
      "type": "string",
      "enum": [
        "reader_known",
        "character_known",
        "hidden"
      ]
    }
  }
}

